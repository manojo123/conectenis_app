# Windows desktop / iOS simulator: http://localhost/api
# Android emulator: http://10.0.2.2/api
# Physical device (same Wi-Fi): http://<your-pc-lan-ip>/api
# Sail exposes port 80 on the host (not 8000).
API_BASE_URL=http://localhost/api
USE_MOCK_API=true
GOOGLE_MAPS_API_KEY=your_google_maps_key
REVERB_APP_KEY=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
