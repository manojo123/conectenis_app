# Windows desktop / iOS simulator: http://localhost/api
# Android emulator: http://10.0.2.2/api
# Physical device (same Wi-Fi): http://<your-pc-lan-ip>/api
# Sail exposes port 80 on the host (not 8000).
API_BASE_URL=http://localhost/api
USE_MOCK_API=true
GOOGLE_MAPS_API_KEY=your_google_maps_key
# OAuth 2.0 Web client ID (same as Laravel GOOGLE_CLIENT_ID) — required for Google login
GOOGLE_OAUTH_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
# Optional: iOS client ID from Google Cloud (type iOS)
GOOGLE_OAUTH_IOS_CLIENT_ID=
REVERB_APP_KEY=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
