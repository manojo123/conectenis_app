{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "conectenis_app (Windows)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "windows",
      "flutterMode": "debug",
      "env": {
        "NUGET_CONFIG": "${workspaceFolder}/nuget.config",
        "PUB_CACHE": "C:\\pub-cache"
      }
    },
    {
      "name": "conectenis_app (Android)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "deviceId": "android",
      "flutterMode": "debug",
      "env": {
        "PUB_CACHE": "C:\\pub-cache"
      }
    },
    {
      "name": "Attach to running Flutter app",
      "request": "attach",
      "type": "dart"
    }
  ]
}
