{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "Debug: conectenis_app (Pixel 8 emulator)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}",
      "deviceId": "emulator-5554",
      "flutterMode": "debug",
      "debugSdkLibraries": false,
      "toolEnv": {
        "PUB_CACHE": "C:\\pub-cache"
      }
    },
    {
      "name": "Debug: conectenis_app (Windows)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}",
      "deviceId": "windows",
      "flutterMode": "debug",
      "debugSdkLibraries": false,
      "screenSize": {
        "width": 412,
        "height": 915
      },

      "toolEnv": {
        "PUB_CACHE": "C:\\pub-cache",
        "NUGET_CONFIG": "${workspaceFolder}/nuget.config"
      }
    }
  ]
}
